# ---------------------------------------------------------------------------
# Matchday Pulse environment
# Copy to .env.local (gitignored) and fill in. Scripts in scripts/ generate
# most of these for you (see README "Setup").
# ---------------------------------------------------------------------------

# App base URL (used to build cNFT metadata + image URIs). Set to your deployed
# URL in production (e.g. https://matchday-pulse.vercel.app).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Solana ---
NEXT_PUBLIC_SOLANA_NETWORK=devnet
# Optional custom RPC for the wallet connection (defaults to devnet).
# NEXT_PUBLIC_SOLANA_RPC_URL=

# Service keypair (devnet): JSON byte array, e.g. [12,34,...]. Used server-side
# as the TxLINE subscriber AND the Bubblegum tree authority / fee-payer.
# Generate + fund with: node scripts/txline-subscribe.mjs (see README).
TXLINE_SERVICE_SECRET=

# --- TxLINE (real World Cup data feed — the primary input) ---
# Devnet host by default; use https://txline.txodds.com for mainnet.
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
# Produced by scripts/txline-subscribe.mjs (guest JWT + activated API token).
TXLINE_JWT=
TXLINE_API_TOKEN=
# Discovered from the fixtures snapshot; filters the feed to the World Cup.
TXLINE_WORLDCUP_COMPETITION_ID=

# --- Metaplex Bubblegum (compressed-NFT minting) ---
# Created once by scripts/create-tree.mjs.
MERKLE_TREE_ADDRESS=

# --- DAS read-back (gallery). Free key from https://helius.dev ---
# Without this, minting still works; the "Your Big Moments" gallery is disabled
# (default devnet RPC can't serve DAS queries).
HELIUS_API_KEY=
